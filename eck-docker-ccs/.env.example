ES_VERSION=9.4.2
ELASTIC_PASSWORD=changeme
KIBANA_PASSWORD=changeme

REMOTE_CLUSTER_NAME=remote-docker
REMOTE_HTTP_PORT=9201
REMOTE_TRANSPORT_PORT=9300
REMOTE_CLUSTER_SERVER_PORT=9443
REMOTE_KIBANA_PORT=5602
INGRESS_HOST_STYLE=short
INGRESS_NGINX_VERSION=1.15.1
K8S_INGRESS_ROLLOUT_TIMEOUT=900s

COMPOSE_PROJECT_NAME=eck-docker-ccs

# Optional: used only by `make llm`.
# Providers: ollama, openai, openai-compatible, bedrock.
LLM_PROVIDER=ollama
LLM_CONNECTOR_ID=ccs-lab-llm
LLM_CONNECTOR_NAME="CCS Lab LLM"
LLM_DOC_COUNT=120
LLM_VALIDATE=true

# Ollama/OpenAI-compatible local endpoint. The default URL is derived at runtime:
# http://<detected-host-ip>:11434/v1/chat/completions
# Leave OLLAMA_MODEL empty to auto-select the first model returned by /api/tags.
OLLAMA_MODEL=
OLLAMA_API_KEY=ollama
# OLLAMA_API_URL=http://10.0.10.130:11434/v1/chat/completions
# OLLAMA_TAGS_URL=http://10.0.10.130:11434/api/tags

# OpenAI provider.
# OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_API_URL=https://api.openai.com/v1/chat/completions

# OpenAI-compatible provider. Set LLM_PROVIDER=openai-compatible and provide:
# LLM_API_URL=https://your-compatible-endpoint/v1/chat/completions
# LLM_API_KEY=
# LLM_MODEL=

# Amazon Bedrock provider. Lowercase names are also accepted for the access keys.
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
BEDROCK_MODEL=us.anthropic.claude-sonnet-4-5-20250929-v1:0
BEDROCK_PROVIDER=anthropic
# BEDROCK_API_URL=https://bedrock-runtime.us-east-1.amazonaws.com
